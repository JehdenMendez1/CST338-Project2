<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="800.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dungeonfighter.controller.UserScoreController">
    <ImageView fitHeight="800.0" fitWidth="1280.0" preserveRatio="true">
        <image>
            <Image url="@../MainMenuBG.jpeg" />
        </image>
    </ImageView>
    
    <VBox alignment="CENTER" spacing="20">

        <Label style="-fx-font-size: 40px; -fx-font-weight: bold;" text="My Scores" textFill="WHITE" />

        <ListView fx:id="scoreList" maxWidth="-Infinity" prefHeight="400" prefWidth="300.0" style="-fx-background-color: transparent;
                                  -fx-control-inner-background: transparent;
                                  -fx-font-size: 20px;
                 -fx-font-weight: bold;
                 -fx-text-fill: white;;" />

        <Button fx:id="backUserScore" prefHeight="60" prefWidth="180" text="BACK">
         <font>
            <Font name="System Bold" size="18.0" />
         </font></Button>

    </VBox>

</StackPane>
